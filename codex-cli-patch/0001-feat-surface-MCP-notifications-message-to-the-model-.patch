diff --git a/codex-rs/rmcp-client/src/logging_client_handler.rs b/codex-rs/rmcp-client/src/logging_client_handler.rs
index 0c3da0f..76aec47 100644
--- a/codex-rs/rmcp-client/src/logging_client_handler.rs
+++ b/codex-rs/rmcp-client/src/logging_client_handler.rs
@@ -1,5 +1,9 @@
 use std::sync::Arc;
 
+use async_channel::Sender;
+use codex_protocol::protocol::Event;
+use codex_protocol::protocol::EventMsg;
+use codex_protocol::protocol::McpServerLogMessageEvent;
 use rmcp::ClientHandler;
 use rmcp::RoleClient;
 use rmcp::model::CancelledNotificationParam;
@@ -23,13 +27,29 @@ use crate::rmcp_client::SendElicitation;
 pub(crate) struct LoggingClientHandler {
     client_info: ClientInfo,
     send_elicitation: Arc<SendElicitation>,
+    /// Name of the MCP server this handler belongs to. Used to tag
+    /// McpServerLogMessage events so the consumer knows which server sent
+    /// the notification.
+    server_name: String,
+    /// Optional channel to send events back to the agent loop. When set,
+    /// info/notice-level log notifications are forwarded as
+    /// McpServerLogMessage events so the model can see and react to them.
+    /// When None, behavior is unchanged (tracing-only delivery).
+    tx_event: Option<Sender<Event>>,
 }
 
 impl LoggingClientHandler {
-    pub(crate) fn new(client_info: ClientInfo, send_elicitation: SendElicitation) -> Self {
+    pub(crate) fn new(
+        client_info: ClientInfo,
+        send_elicitation: SendElicitation,
+        server_name: String,
+        tx_event: Option<Sender<Event>>,
+    ) -> Self {
         Self {
             client_info,
             send_elicitation: Arc::new(send_elicitation),
+            server_name,
+            tx_event,
         }
     }
 }
@@ -102,7 +122,9 @@ impl ClientHandler for LoggingClientHandler {
             logger,
             data,
         } = params;
-        let logger = logger.as_deref();
+        let logger_str = logger.as_deref();
+
+        // Existing behavior: route to tracing infrastructure (unchanged).
         match level {
             LoggingLevel::Emergency
             | LoggingLevel::Alert
@@ -110,27 +132,61 @@ impl ClientHandler for LoggingClientHandler {
             | LoggingLevel::Error => {
                 error!(
                     "MCP server log message (level: {:?}, logger: {:?}, data: {})",
-                    level, logger, data
+                    level, logger_str, data
                 );
             }
             LoggingLevel::Warning => {
                 warn!(
                     "MCP server log message (level: {:?}, logger: {:?}, data: {})",
-                    level, logger, data
+                    level, logger_str, data
                 );
             }
             LoggingLevel::Notice | LoggingLevel::Info => {
                 info!(
                     "MCP server log message (level: {:?}, logger: {:?}, data: {})",
-                    level, logger, data
+                    level, logger_str, data
                 );
             }
             LoggingLevel::Debug => {
                 debug!(
                     "MCP server log message (level: {:?}, logger: {:?}, data: {})",
-                    level, logger, data
+                    level, logger_str, data
                 );
             }
         }
+
+        // NEW: for info-level and above, also forward to the agent loop
+        // so the model can see the notification and react to it. This
+        // enables MCP servers (e.g., inter-agent peer messaging, CI
+        // watchers, file-change monitors) to surface real-time
+        // information to the model mid-task — not just to stderr.
+        //
+        // Debug-level is excluded to avoid flooding the model's context
+        // with verbose diagnostic output.
+        if !matches!(level, LoggingLevel::Debug) {
+            if let Some(tx) = &self.tx_event {
+                let data_str = match &data {
+                    serde_json::Value::String(s) => s.clone(),
+                    other => other.to_string(),
+                };
+                let _ = tx
+                    .send(Event {
+                        id: format!(
+                            "mcp_server_log_{}",
+                            std::time::SystemTime::now()
+                                .duration_since(std::time::UNIX_EPOCH)
+                                .unwrap_or_default()
+                                .as_millis()
+                        ),
+                        msg: EventMsg::McpServerLogMessage(McpServerLogMessageEvent {
+                            server: self.server_name.clone(),
+                            logger: logger.clone(),
+                            level: format!("{:?}", level).to_lowercase(),
+                            data: data_str,
+                        }),
+                    })
+                    .await;
+            }
+        }
     }
 }
