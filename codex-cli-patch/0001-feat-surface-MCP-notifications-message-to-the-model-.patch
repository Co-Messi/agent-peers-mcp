diff --git a/codex-rs/protocol/src/protocol.rs b/codex-rs/protocol/src/protocol.rs
index 244f748..8f11da8 100644
--- a/codex-rs/protocol/src/protocol.rs
+++ b/codex-rs/protocol/src/protocol.rs
@@ -1520,6 +1520,13 @@ pub enum EventMsg {
 
     BackgroundEvent(BackgroundEventEvent),
 
+    /// An MCP server sent a `notifications/message` log notification with
+    /// level info or higher. Unlike tracing-only delivery, this variant
+    /// surfaces the notification content to the model's conversation so
+    /// the LLM can read and react to it (e.g., an inter-agent peer
+    /// message, a CI result, a file-change alert).
