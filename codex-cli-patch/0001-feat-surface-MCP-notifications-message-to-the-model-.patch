+
     UndoStarted(UndoStartedEvent),
 
     UndoCompleted(UndoCompletedEvent),
@@ -3288,6 +3295,31 @@ pub struct McpStartupFailure {
     pub error: String,
 }
 
+/// Emitted when an MCP server sends a `notifications/message` log
+/// notification that should be surfaced to the model's conversation
+/// (level info or higher). The `data` field carries the notification
+/// payload — typically a human-readable string or structured JSON that
+/// the model should see and potentially act on.
+///
+/// Use case: an MCP server for inter-agent peer messaging pushes a
+/// "you have a new message from peer X" notification. With this event
+/// surfaced to the model, the LLM can decide to check its inbox or
+/// respond to the peer — without requiring the user to manually trigger
+/// a tool call.
+#[derive(Debug, Clone, Deserialize, Serialize, JsonSchema, TS)]
+pub struct McpServerLogMessageEvent {
+    /// Name of the MCP server that sent the notification.
+    pub server: String,
+    /// The `logger` field from the notification params (if set).
+    #[serde(skip_serializing_if = "Option::is_none")]
+    pub logger: Option<String>,
+    /// The `level` field from the notification (e.g., "info", "notice").
+    pub level: String,
+    /// The `data` payload from the notification, serialized as a string.
+    /// Typically contains the message text the model should see.
+    pub data: String,
+}
+
 #[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, JsonSchema, TS)]
 #[serde(rename_all = "snake_case")]
 #[ts(rename_all = "snake_case")]
